programa {
  funcao inicio() {
    real profundidade

    escreva("Em qual profundidade o subimarino esta? ")
    leia(profundidade)

      se (profundidade>1000){
      escreva("Esmagamento iminente")
      }

      senao se (profundidade>500){
        escreva("Alerta")
      }

       senao
      escreva("Navegação segura")
      


      }
    }  
  

