programa {
  funcao inicio() {
    real n1, n2

    escreva("Qual foi sua nota?")
    leia(n1)
    escreva("Qual sua renda mensal?")
    leia(n2)

      se(n1>8 e n2<2000) {
      escreva("Parabens voce ganhou a bolsa")
    }
      senao {
      escreva("Você não pode ganhar a bolsa")
      }
  }
}
  

